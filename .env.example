# === Безопасность ===
# SECRET_KEY — генерируется автоматически при первом запуске
# Или задайте вручную (минимум 64 символа):
# SECRET_KEY=your-random-64-char-string-here

# === База данных (PostgreSQL) ===
DATABASE_URL=postgresql+asyncpg://myshop:myshop_secret@localhost:5432/myshop

# === Redis ===
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# === RabbitMQ ===
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# === Сервер ===
HOST=0.0.0.0
PORT=8000
DEBUG=false

# === CORS ===
CORS_ORIGINS=["https://yourdomain.com"]

# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === S3 / MinIO ===
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=myshop-uploads
S3_REGION=us-east-1

# === Sentry ===
SENTRY_DSN=

# === YooKassa (платежи) ===
# Регистрация: https://yookassa.ru
# Sandbox: https://yookassa.ru/my/shop-settings
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
